# ---- tg-api ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=1440
ADMIN_EMAIL=admin@trustgraph.local
ADMIN_PASSWORD=change-me

# ---- trustgraph-ai ----
TG_API_URL=http://trustgraph:8088
TG_API_KEY=change-me-trustgraph-key
TG_KNOWLEDGE_CORE=trustgraph-security
TG_COLLECTION=default
TG_FLOW_ID=security-rag
# Pin the trustgraph-flow image tag. Docker Hub does NOT publish `:latest`.
TG_FLOW_VERSION=2.5.13

# ---- redis / celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- CAI pentest agent ----
# Provide at least one model provider key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CAI_MODEL=anthropic/claude-sonnet-4-5
CAI_MAX_TURNS=25
CAI_TIMEOUT_SEC=600

# ---- GitHub App enrichment ----
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github_app.pem
GITHUB_WEBHOOK_SECRET=

# ---- Scanners ----
SEMGREP_RULES=p/default
TRIVY_SEVERITY=HIGH,CRITICAL
NUCLEI_TEMPLATES=cves,exposures,misconfiguration

# ---- Feeds (customized prior-process ingest) ----
FEED_LOCAL_PATH=/data/feeds
FEED_S3_BUCKET=
FEED_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
